# =====================================
# BEAUTYBRAIN AI — Environment Variables Template
# =====================================
# Salin file ini menjadi .env lalu isi nilainya.
# File .env TIDAK boleh di-commit ke Git.

# =====================================
# GROQ API
# Dapatkan API key di: https://console.groq.com/keys
# =====================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# =====================================
# DATABASE
# - Development (lokal): kosongkan → otomatis pakai SQLite
# - Production (Railway): isi dengan URL dari Railway MySQL plugin
# =====================================
DATABASE_URL=mysql+pymysql://user:password@host:3306/beautybrain

# =====================================
# CORS — URL Frontend yang diizinkan
# Pisahkan dengan koma jika lebih dari satu
# Contoh lokal  : http://localhost:3000,http://localhost:5173
# Contoh hosting: https://beautybrain.vercel.app
# =====================================
FRONTEND_URL=http://localhost:3000,http://localhost:5173

